# 本地示例（可按实际修改）
DATABASE_URL="mysql://root:root@127.0.0.1:3306/project_mgmt"
JWT_ACCESS_SECRET="replace-with-access-secret"
JWT_REFRESH_SECRET="replace-with-refresh-secret"
# Access 默认 2h；401 时前端 POST /api/auth/refresh。Refresh 默认 7d（整段登录可续期上限）。Cookie maxAge 与下列变量一致（见 src/lib/cookies.ts）。
JWT_ACCESS_EXPIRES_IN="2h"
JWT_REFRESH_EXPIRES_IN="7d"
COOKIE_DOMAIN=""
COOKIE_SECURE="false"

# IM 消息在 MySQL 中保留天数（默认 30 ≈ 1 个月；IM Socket 启动时会清理过期行，也可用 npm run db:prune-im）
# IM_RETENTION_DAYS=30
# IM Socket 启动时不自动删库：IM_PRUNE_ON_START=false
# 只统计不删除：IM_PRUNE_DRY_RUN=1 npm run db:prune-im

# 可选：项目概览「邮件」提醒（nodemailer）
# 优先使用管理后台「系统配置 · 邮件」写入数据库；未配置库表时可使用环境变量回退：
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=noreply@example.com
# 库内 SMTP 口令加密密钥（建议生产单独设置；缺省则使用 JWT_REFRESH_SECRET 派生）
# SETTINGS_ENCRYPTION_SECRET=
# 截止/日历提醒：进程内 node-cron（无需外部定时调 HTTP）
# 仅 next dev / next start（无 IM 栈）时开启：
# DEADLINE_REMINDER_IN_NEXT=true
# dev:stack 与 IM 同开时请保持未设置或 false，避免与 IM 内 cron 重复扫描
# DEADLINE_REMINDER_IN_IM=false
# 扫描间隔（毫秒，15s～60min），会映射为 cron；或直接写 cron 覆盖：
# DEADLINE_REMINDER_INTERVAL_MS=60000
# DEADLINE_REMINDER_CRON=0 * * * * *
# 手动触发 HTTP 时与 INTERNAL_CRON_SECRET 一致（至少 8 位）：
# INTERNAL_CRON_SECRET=change-me-at-least-8-chars

